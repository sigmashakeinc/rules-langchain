# langchain_write_safety.rules
# Technology: langchain | Capability: write

rule langchain-block-unsafe-patterns {
  enabled true
  priority 90
  severity error
  DENY write
  IF path GLOB "**/*" AND content CONTAINS "LLMMathChain"
  MESSAGE "Blocked an unsafe pattern in langchain. Use the recommended best practices for 2025/2026."
}

rule langchain-force-updated-api {
  enabled true
  priority 80
  severity warning
  LOG write
  IF path GLOB "**/*" AND content CONTAINS "LLMChain"
  MESSAGE "You are using an outdated API for langchain. Please upgrade to the newer API."
}
